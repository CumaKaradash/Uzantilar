{
  "manifest_version": 3,
  "name": "İG Odak",
  "description": "Instagram'daki dikkat dağıtıcı unsurları (Reels, Keşfet, Bildirimler) gizleyerek daha odaklı bir gezinme deneyimi sunar.",
  "version": "1.0.0",
  "action": {
    "default_title": "İG Odak",
    "default_popup": "popup.html",
    "default_icon": "icons/coffee.png"
  },
  "icons": {
    "16": "icons/coffee.png",
    "32": "icons/coffee.png",
    "48": "icons/coffee.png",
    "128": "icons/coffee.png"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}